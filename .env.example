# Application
APP_ENV=local
APP_NAME=cf-ai-card
APP_BASE_URL=http://localhost:5173
CARD_WEB_BASE_URL=http://localhost:4173
ADMIN_BASE_URL=http://localhost:4174
API_BASE_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
CORS_ALLOWED_ORIGINS=["http://127.0.0.1:4173","http://localhost:4173","http://127.0.0.1:4174","http://localhost:4174"]

# PostgreSQL / pgvector (local development only)
POSTGRES_DB=cf_ai_card
POSTGRES_USER=cf_ai_card
POSTGRES_PASSWORD=change-me-local-only
APP_DB_USER=cf_ai_card_app
APP_DB_PASSWORD=change-me-app-local-only
WORKER_DB_USER=cf_ai_card_worker
WORKER_DB_PASSWORD=change-me-worker-local-only
DATABASE_URL=postgresql+asyncpg://cf_ai_card_app:change-me-app-local-only@127.0.0.1:5432/cf_ai_card
MIGRATION_DATABASE_URL=postgresql+asyncpg://cf_ai_card:change-me-local-only@127.0.0.1:5432/cf_ai_card
WORKER_DATABASE_URL=postgresql+asyncpg://cf_ai_card_worker:change-me-worker-local-only@127.0.0.1:5432/cf_ai_card

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Durable outbox Worker
WORKER_ID=local-worker
OUTBOX_POLL_SECONDS=1
OUTBOX_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=900
OUTBOX_HEARTBEAT_SECONDS=60
OUTBOX_MAX_ATTEMPTS=6
OUTBOX_BACKOFF_BASE_SECONDS=5
OUTBOX_BACKOFF_MAX_SECONDS=900
EXPORT_RETENTION_HOURS=24
EXPORT_MAX_ROWS=100000
PROFILE_RETENTION_PURGE_SECONDS=3600
SCHEDULED_PUBLISH_POLL_SECONDS=5
SCHEDULED_PUBLISH_BATCH_SIZE=10
SCHEDULED_PUBLISH_LEASE_SECONDS=900
SCHEDULED_PUBLISH_MAX_ATTEMPTS=6
KNOWLEDGE_IMPORT_POLL_SECONDS=3
KNOWLEDGE_IMPORT_BATCH_SIZE=10
KNOWLEDGE_IMPORT_LEASE_SECONDS=900
KNOWLEDGE_IMPORT_MAX_ATTEMPTS=6
WORKER_HEALTH_HOST=127.0.0.1
WORKER_HEALTH_PORT=8020
EVALUATION_DATASET_DIR=packages/evals
EVALUATION_SUITE_VERSION=v2

# Object storage (local MinIO)
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=local
OBJECT_STORAGE_BUCKET=cf-ai-card-local
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=change-me-local-only
OBJECT_STORAGE_SECURE=false

# Authentication / encryption - use secret manager references outside local
JWT_SIGNING_KEY=replace-with-at-least-32-random-bytes
FIELD_ENCRYPTION_KEY=replace-with-kms-backed-key
FIELD_ENCRYPTION_KEY_REF=local-v1
# Optional secret JSON map used only while decrypting data written with retired keys.
FIELD_ENCRYPTION_PREVIOUS_KEYS=
# Comma-separated CIDRs or a JSON array. Forwarded IP headers are ignored unless
# the direct peer is inside one of these networks.
TRUSTED_PROXY_CIDRS=
ACCESS_TOKEN_TTL_SECONDS=900
VISITOR_TOKEN_TTL_SECONDS=7200
PROFILE_LINK_TOKEN_TTL_SECONDS=15552000
VISITOR_PROFILE_RETENTION_DAYS=365
REFRESH_TOKEN_TTL_SECONDS=604800
STAFF_LOGIN_MAX_FAILURES=5
STAFF_LOGIN_LOCK_SECONDS=900
STAFF_LOGIN_IP_RATE_LIMIT_PER_MINUTE=30
STAFF_LOGIN_ACCOUNT_RATE_LIMIT_PER_MINUTE=10
STAFF_REFRESH_IP_RATE_LIMIT_PER_MINUTE=60
STAFF_REFRESH_COOKIE_NAME=cf_staff_refresh
STAFF_CSRF_COOKIE_NAME=cf_staff_csrf
# Set true behind HTTPS. Production validation rejects false.
STAFF_AUTH_COOKIE_SECURE=false
STAFF_AUTH_COOKIE_SAMESITE=strict
# Optional one-time seed bootstrap; configure all three together in .env.local.
ADMIN_BOOTSTRAP_TENANT_SLUG=
ADMIN_BOOTSTRAP_ACCOUNT=
ADMIN_BOOTSTRAP_PASSWORD=

# LLM provider
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_THINKING=disabled
LLM_REASONING_EFFORT=high
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=1000
LLM_TEMPERATURE=0.1
LLM_MAX_CONCURRENCY=20
LLM_QUEUE_TIMEOUT_SECONDS=3
LLM_MAX_RETRIES=2
# Operator-maintained CNY estimates per 1M tokens; refresh when provider pricing/FX changes
LLM_INPUT_PRICE_CNY_PER_MILLION=0
LLM_OUTPUT_PRICE_CNY_PER_MILLION=0

# Embedding provider - dimension must match the database migration
# The Windows one-click runtime uses local-fastembed at http://127.0.0.1:8010/v1
# with intfloat/multilingual-e5-large. Keep these blank for lexical-only/Compose setups
# unless the embedding endpoint is reachable from the API process.
EMBEDDING_PROVIDER=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_SECONDS=20

# Retrieval; thresholds must be calibrated against each release's evaluation set
RETRIEVAL_TOP_K=8
RETRIEVAL_CONTEXT_K=5
RETRIEVAL_VECTOR_WEIGHT=0.65
RETRIEVAL_MIN_VECTOR_SCORE=0.55
RETRIEVAL_MIN_LEXICAL_SCORE=0.08

# Guardrails and budgets
PUBLIC_CHAT_RATE_LIMIT_PER_MINUTE=10
PUBLIC_CHAT_IP_CARD_RATE_LIMIT_PER_MINUTE=20
PUBLIC_VISIT_IP_CARD_RATE_LIMIT_PER_MINUTE=60
MAX_MESSAGE_CHARS=2000
MAX_CONVERSATION_MESSAGES=30
MODEL_DAILY_BUDGET_CNY=100

# Retention defaults; legal/product owners must confirm before production
ANONYMOUS_EVENT_RETENTION_DAYS=90
CONVERSATION_RETENTION_DAYS=180
LEAD_RETENTION_DAYS=180
AUDIT_RETENTION_DAYS=730

# Observability
LOG_LEVEL=INFO
# Required in staging/production. Use a random secret delivered by the secret manager.
METRICS_BEARER_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
