# Application
APP_ENV=local
APP_NAME=cf-ai-card
APP_BASE_URL=http://localhost:5173
CARD_WEB_BASE_URL=http://localhost:4173
ADMIN_BASE_URL=http://localhost:5174
API_BASE_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
CORS_ALLOWED_ORIGINS=["http://127.0.0.1:4173","http://localhost:4173"]

# PostgreSQL / pgvector (local development only)
POSTGRES_DB=cf_ai_card
POSTGRES_USER=cf_ai_card
POSTGRES_PASSWORD=change-me-local-only
APP_DB_USER=cf_ai_card_app
APP_DB_PASSWORD=change-me-app-local-only
DATABASE_URL=postgresql+asyncpg://cf_ai_card_app:change-me-app-local-only@localhost:5432/cf_ai_card
MIGRATION_DATABASE_URL=postgresql+asyncpg://cf_ai_card:change-me-local-only@localhost:5432/cf_ai_card

# Redis
REDIS_URL=redis://localhost:6379/0

# Object storage (local MinIO)
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=local
OBJECT_STORAGE_BUCKET=cf-ai-card-local
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=change-me-local-only
OBJECT_STORAGE_SECURE=false

# Authentication / encryption - use secret manager references outside local
JWT_SIGNING_KEY=replace-with-at-least-32-random-bytes
FIELD_ENCRYPTION_KEY=replace-with-kms-backed-key
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# LLM provider
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_THINKING=disabled
LLM_REASONING_EFFORT=high
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=1000
LLM_TEMPERATURE=0.1
LLM_MAX_CONCURRENCY=20
LLM_QUEUE_TIMEOUT_SECONDS=3
LLM_MAX_RETRIES=2
# Operator-maintained CNY estimates per 1M tokens; refresh when provider pricing/FX changes
LLM_INPUT_PRICE_CNY_PER_MILLION=0
LLM_OUTPUT_PRICE_CNY_PER_MILLION=0

# Embedding provider - dimension must match the database migration
# The Windows one-click runtime uses local-fastembed at http://127.0.0.1:8010/v1
# with intfloat/multilingual-e5-large. Keep these blank for lexical-only/Compose setups
# unless the embedding endpoint is reachable from the API process.
EMBEDDING_PROVIDER=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_SECONDS=20

# Retrieval; thresholds must be calibrated against each release's evaluation set
RETRIEVAL_TOP_K=8
RETRIEVAL_CONTEXT_K=5
RETRIEVAL_VECTOR_WEIGHT=0.65
RETRIEVAL_MIN_VECTOR_SCORE=0.55
RETRIEVAL_MIN_LEXICAL_SCORE=0.08

# Guardrails and budgets
PUBLIC_CHAT_RATE_LIMIT_PER_MINUTE=10
MAX_MESSAGE_CHARS=2000
MAX_CONVERSATION_MESSAGES=30
MODEL_DAILY_BUDGET_CNY=100

# Retention defaults; legal/product owners must confirm before production
ANONYMOUS_EVENT_RETENTION_DAYS=90
CONVERSATION_RETENTION_DAYS=180
LEAD_RETENTION_DAYS=180
AUDIT_RETENTION_DAYS=730

# Observability
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
